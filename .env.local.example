# Resend API key for contact form (/api/send) and sign-up emails (/api/signup)
RESEND_API_KEY=xxx

# Verified sender address in Resend (e.g. contact@alvinchiew.com)
FROM_EMAIL=xxx@xxx.com

# Activation key validator (required for sign-up form)
ACTIVATION_ISSUE_URL=https://xxx.xxx.com/xxx
ACTIVATION_ISSUE_API_KEY=xxx
